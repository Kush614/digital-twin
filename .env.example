# --- LLM / Vision (Z.AI primary) ---
# Single key:
ZAI_API_KEY=
# OR pool — comma-separated. The app tries them in order; on a billing /
# quota error the offending key is parked on a 5-minute cooldown and the
# next key is tried automatically. Both vars are read; pool takes priority.
ZAI_API_KEYS=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-4.5
# Vision-language model used by /api/vision/analyze and /api/asl/recognize
ZAI_VISION_MODEL=glm-4.5v
# Fallback for the text evaluator when all Z.AI keys are down
ANTHROPIC_API_KEY=

# --- GitHub API (optional — boosts rate limit from 60 to 5000 req/h) ---
# Create a fine-grained token with `public_repo` read at https://github.com/settings/tokens
GITHUB_TOKEN=

# --- SpatialReal (optional — reviewer-narrator avatar on /a/[id]) ---
# Get from https://app.spatialreal.ai/apps (Create API Key → copy both)
SPATIALREAL_APP_ID=
SPATIALREAL_API_KEY=
# us-west or ap-northeast
SPATIALREAL_REGION=us-west
# Pick from https://app.spatialreal.ai/avatars/library (hover card → copy id)
SPATIALREAL_AVATAR_ID=
# Public mirrors so the SDK can read appId + avatarId on the client
NEXT_PUBLIC_SPATIALREAL_APP_ID=
NEXT_PUBLIC_SPATIALREAL_REGION=us-west
NEXT_PUBLIC_SPATIALREAL_AVATAR_ID=

# --- EAS (Ethereum Attestation Service) — optional, on-chain attestation layer ---
# Free on Base Sepolia. Uses the same private key as the deployer.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
EAS_PRIVATE_KEY=
# Schema UID gets printed by `npm run register:schema` and pasted here.
EAS_SCHEMA_UID=
NEXT_PUBLIC_EAS_SCHEMA_UID=
NEXT_PUBLIC_EAS_CHAIN=base-sepolia
